{
  "name": "borg-orchestrator-vscode",
  "displayName": "Borg Orchestrator",
  "description": "Multi-model AI council debates and autonomous code generation directly in your editor.",
  "version": "1.0.30",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Machine Learning",
    "Programming Languages"
  ],
  "activationEvents": [
    "onCommand:borg.startDashboard",
    "onCommand:borg.debateSelection"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "borg.startDashboard",
        "title": "Borg: Open Dashboard"
      },
      {
        "command": "borg.debateSelection",
        "title": "Borg: Debate Selected Code"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "borg.debateSelection",
          "group": "borg@1"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0"
  }
}
